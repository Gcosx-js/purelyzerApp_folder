     <property name="styleSheet">
      <string notr="true">/* QTableWidget için Dark Theme */

QTableWidget {
    background-color:rgba(20,20,20,255);;   /* Arka plan rengi: Koyu gri */
    color: #f0f0f0;              /* Metin rengi: Beyaz */
    gridline-color: #3e3e3e;     /* Hücre ızgara çizgileri: Orta gri */
    border: 1px solid #3e3e3e;   /* Dış sınır: Orta gri */
	border-radius:15px;
}

QHeaderView::section {
    background-color: #3e3e3e;   /* Başlık arka plan rengi: Orta gri */
    color: #f0f0f0;              /* Başlık metin rengi: Beyaz */
    padding: 4px;
    border: 1px solid #2b2b2b;   /* Başlık kenarlık rengi: Koyu gri */
}

QTableWidget::item {
    selection-background-color: #444444; /* Seçili öğe arka plan rengi: Koyu gri */
    selection-color: #ffffff;            /* Seçili öğe metin rengi: Beyaz */
}

QTableWidget::item:selected {
    background-color: #444444; /* Seçili öğe arka plan rengi: Koyu gri */
    color: #ffffff;            /* Seçili öğe metin rengi: Beyaz */
	border:1px solid yellow;
}
QTableCornerButton::section {
    background-color: #2b2b2b; /* Rengi koyu gri olarak değiştir */
    border: 1px solid #3e3e3e; /* Kenarlık rengi orta gri */
}

QScrollBar:vertical {
    background-color: #2b2b2b; /* Dikey kaydırma çubuğu arka plan rengi: Koyu gri */
    width: 15px;
    margin: 0px 3px 0px 3px;
}

QScrollBar::handle:vertical {
    background-color: #5a5a5a; /* Dikey kaydırma çubuğu tutamağı: Gri */
    min-height: 20px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background-color: #3e3e3e; /* Kaydırma çubuğu butonları: Orta gri */
    height: 15px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}</string>
     </property>
